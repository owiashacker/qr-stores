# ============================================
# QR Stores - Root .htaccess Security
# ============================================

# --- Disable directory listing ---
Options -Indexes -MultiViews

# --- Custom error pages ---
# المسار يُعدّل تلقائياً عند الـ deploy على السيرفر (راجع .cpanel.yml)
ErrorDocument 404 /qr_stores/404.php
ErrorDocument 403 /qr_stores/404.php
# DEPLOY_MARKER_404 — لا تحذف هذا التعليق، يستخدمه سكربت الـ deploy

# --- DirectoryIndex so folders resolve to login.php instead of falling through to other apps ---
DirectoryIndex index.php login.php

# --- Follow symlinks for rewriting ---
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Force HTTPS (uncomment in production)
    # RewriteCond %{HTTPS} !=on
    # RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

    # Block null-byte and bad query strings
    RewriteCond %{QUERY_STRING} (\<|%3C).*script.*(\>|%3E) [NC,OR]
    RewriteCond %{QUERY_STRING} GLOBALS(=|\[|\%[0-9A-Z]{0,2}) [OR]
    RewriteCond %{QUERY_STRING} _REQUEST(=|\[|\%[0-9A-Z]{0,2}) [OR]
    RewriteCond %{QUERY_STRING} proc/self/environ [NC,OR]
    RewriteCond %{QUERY_STRING} base64_(en|de)code[^(]*\([^)]*\) [NC]
    RewriteRule ^(.*)$ - [F,L]

    # Block access to sensitive file extensions anywhere in the tree
    RewriteRule \.(sql|log|env|bak|backup|old|swp|dist|ini|conf|config|sh|bash)$ - [F,L]

    # Block access to hidden files and VCS folders
    RewriteRule (^|/)\.(?!well-known) - [F,L]

    # ─── Silence common scanner / hack-attempt requests ──────────────
    # These return a clean 410 (Gone) without logging — reduces error log noise
    # from bots probing for WordPress, phpMyAdmin, .env files, etc.
    RewriteRule ^(wp-login|wp-admin|wp-includes|wp-content|wp-config|xmlrpc)\.php?$ - [G,L]
    RewriteRule ^wp-(login|admin|includes|content)/ - [G,L]
    RewriteRule ^(phpmyadmin|pma|phpMyAdmin|mysql|adminer|administrator|admin\.php)/?$ - [G,L]
    RewriteRule ^(boaform|cgi-bin|owa|autodiscover|fckeditor)/ - [G,L]
    RewriteRule ^\.env(\..+)?$ - [G,L]
    RewriteRule ^(setup|install|backup|backups|database|db|sql|dump|backup\.sql)/?$ - [G,L]
</IfModule>

# --- Security headers (fallback for non-PHP assets) ---
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    Header always unset X-Powered-By
    Header unset Server
</IfModule>

# --- Block search-engine indexing of admin/private areas ---
# Sent as HTTP header instead of being listed in robots.txt — keeps the
# directory names hidden from anyone reading robots.txt while still
# instructing Google/Bing not to index these pages.
<IfModule mod_rewrite.c>
    RewriteCond %{REQUEST_URI} ^/(admin|super|affiliate|migrations|config|includes|assets/uploads)(/|$) [NC]
    RewriteRule .* - [E=PRIVATE_AREA:1]
</IfModule>
<IfModule mod_headers.c>
    Header set X-Robots-Tag "noindex, nofollow, noarchive, nosnippet" env=PRIVATE_AREA
</IfModule>

# --- Block direct access to dotfiles and sensitive files ---
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

<FilesMatch "\.(sql|md|log|ini|conf|env|bak|example|dist)$">
    Require all denied
</FilesMatch>

# --- Disable server signature ---
ServerSignature Off

# --- Limit upload size (defense in depth) ---
<IfModule mod_php.c>
    php_value upload_max_filesize 5M
    php_value post_max_size 6M
    php_value max_input_time 60
    php_value max_execution_time 60
    php_flag expose_php off
    php_flag display_errors off
    php_flag log_errors on
    php_flag session.cookie_httponly on
    php_flag session.use_only_cookies on
    php_value session.cookie_samesite "Lax"
</IfModule>

# ============================================================
# PERFORMANCE OPTIMIZATIONS
# ============================================================

# --- Brotli compression (faster than gzip, smaller files) ---
<IfModule mod_brotli.c>
    AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml application/x-font-ttf application/vnd.ms-fontobject font/opentype image/svg+xml image/x-icon
</IfModule>

# --- Gzip compression (fallback for older clients) ---
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/json application/xml application/xhtml+xml application/rss+xml
    AddOutputFilterByType DEFLATE application/x-font-ttf application/vnd.ms-fontobject font/opentype
    AddOutputFilterByType DEFLATE image/svg+xml image/x-icon
</IfModule>

# --- PHP-level compression (works on shared hosts where mod_deflate is off) ---
<IfModule mod_php.c>
    php_flag zlib.output_compression On
    php_value zlib.output_compression_level 6
</IfModule>

# --- Browser caching (huge speedup for returning visitors) ---
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"

    # HTML — short cache (always freshest)
    ExpiresByType text/html "access plus 0 seconds"

    # CSS / JS — 1 month (use ?v= query strings to bust cache)
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"

    # Images — 1 year (almost never change after upload)
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"

    # Fonts — 1 year
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
    ExpiresByType application/x-font-ttf "access plus 1 year"
    ExpiresByType application/vnd.ms-fontobject "access plus 1 year"

    # Audio / Video — 1 month
    ExpiresByType audio/ogg "access plus 1 month"
    ExpiresByType video/mp4 "access plus 1 month"
    ExpiresByType video/ogg "access plus 1 month"
    ExpiresByType video/webm "access plus 1 month"
</IfModule>

# --- Cache-Control headers (more granular than Expires) ---
<IfModule mod_headers.c>
    # Long cache for static assets (immutable = browser never re-validates)
    <FilesMatch "\.(jpg|jpeg|png|webp|gif|svg|ico|woff|woff2|ttf|otf|eot)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
        Header unset ETag
    </FilesMatch>
    FileETag None

    # Short cache for CSS/JS (can use ?v= versioning to bust)
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>

    # No cache for HTML/PHP (always fresh)
    <FilesMatch "\.(html|php)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
    </FilesMatch>

    # Enable HTTP/2 server push hints for the homepage
    <FilesMatch "index\.php$">
        Header add Link "<https://fonts.googleapis.com>; rel=preconnect"
        Header add Link "<https://fonts.gstatic.com>; rel=preconnect; crossorigin"
        Header add Link "<https://cdn.tailwindcss.com>; rel=preconnect"
    </FilesMatch>
</IfModule>

# --- Disable ETag (we use Cache-Control + Last-Modified instead) ---
FileETag None

# --- Reduce keep-alive overhead ---
<IfModule mod_headers.c>
    Header set Connection keep-alive
</IfModule>
